/*
 * app.overlay — Device Tree overlay Heltec WiFi LoRa 32 V3
 *
 * La LED onboard du Heltec V3 est sur GPIO1 pin 35 (GPIO_NUM_35).
 * On définit l'alias "led0" pour y accéder via DT_ALIAS(led0).
 */
/ {
    aliases {
        led0 = &user_led;
    };

    leds {
        compatible = "gpio-leds";
        user_led: led_0 {
            gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
            label = "User LED";
        };
    };
};
